{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "include-component-in-tag": false,
  "include-v-in-tag": true,
  "packages": {
    ".": {
      "release-type": "simple",
      "package-name": "phai",
      "extra-files": [
        { "type": "toml", "path": "crates/phai-cli/Cargo.toml", "jsonpath": "$.package.version" },
        { "type": "toml", "path": "crates/phai-core/Cargo.toml", "jsonpath": "$.package.version" }
      ]
    }
  }
}
